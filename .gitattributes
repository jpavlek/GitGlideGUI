# Git Glide GUI line-ending policy
# Windows-first project: PowerShell and batch files should be CRLF.
# Text/code files are normalized by Git to avoid mixed-line-ending noise.

* text=auto

# Windows scripts
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Cross-platform/script/config text files
*.py   text eol=lf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Documentation and structured data
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.csv  text eol=lf

# Git metadata/helpers
.gitattributes text eol=lf
.gitignore     text eol=lf

# Binary/archive files
*.zip  binary
*.7z   binary
*.tar  binary
*.gz   binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.exe  binary
*.dll  binary